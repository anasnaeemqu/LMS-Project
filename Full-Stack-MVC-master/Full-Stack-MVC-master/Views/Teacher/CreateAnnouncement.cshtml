@model mvcLab.Models.Announcement

@{
    ViewData["Title"] = "Create Announcement";
}

<div class="lms-welcome">
    <div>
        <h1><i class="fa fa-bullhorn" style="color:#f6a623;"></i> Create Announcement</h1>
        <p>Post an update for all students in this course.</p>
    </div>
</div>

<div class="lms-panel">
    <div class="lms-panel-header">
        <h2 class="lms-panel-title">
            <span class="panel-icon"><i class="fa fa-pencil"></i></span>
            Announcement Details
        </h2>
    </div>
    <div class="lms-panel-body">
        <form asp-action="CreateAnnouncement">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CourseId" value="@ViewBag.CourseId" />
            
            <div class="mb-3">
                <label asp-for="Title" class="form-label font-weight-bold">Title</label>
                <input asp-for="Title" class="form-control" placeholder="Enter a descriptive title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="mb-4">
                <label asp-for="Content" class="form-label font-weight-bold">Content</label>
                <textarea asp-for="Content" class="form-control" rows="5" placeholder="Write your announcement here..."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            
            <div class="d-flex gap-2">
                <button type="submit" class="lms-btn-sm lms-btn-primary">
                    <i class="fa fa-paper-plane"></i> Post Announcement
                </button>
                <a asp-action="CourseDetails" asp-route-id="@ViewBag.CourseId" class="lms-btn-sm lms-btn-outline">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
