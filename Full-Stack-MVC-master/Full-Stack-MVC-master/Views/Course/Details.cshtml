@model Course

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Course Details</h1>
            @if (Model != null)
            {
                <partial name="_CourseCardPV" model="Model" />
            }
            else
            {
                <div class="alert alert-warning">
                    Course not found.
                </div>
            }
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <h5 class="mb-0 text-primary"><i class="fa fa-bullhorn me-2"></i> Announcements</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Announcements != null && ((IEnumerable<mvcLab.Models.Announcement>)ViewBag.Announcements).Any())
                    {
                        foreach (var n in (IEnumerable<mvcLab.Models.Announcement>)ViewBag.Announcements)
                        {
                            <div class="mb-4 border-bottom pb-2">
                                <h6 class="mb-1 text-dark fw-bold">@n.Title</h6>
                                <p class="mb-2 text-muted small">@n.Content</p>
                                <small class="text-muted d-block" style="font-size: 0.75rem;">
                                    <i class="fa fa-clock me-1"></i> @n.DatePosted.ToString("MMM dd, yyyy")
                                </small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fa fa-info-circle mb-2 d-block fs-4"></i>
                            No announcements yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>